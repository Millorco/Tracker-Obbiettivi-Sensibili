# ============================================
# GPS TRACKER - Configurazione
# Copia questo file come .env e modifica i valori
# ============================================

# --- SICUREZZA ---
APP_PASSWORD=admin123
SECRET_KEY=cambia-questa-chiave-segreta-lunga

# --- SERVER FTP ---
FTP_USER=ftpuser
FTP_PASS=ftppassword
# Inserisci l'IP pubblico del server per connessioni FTP passive dall'esterno
SERVER_IP=

# --- EMAIL (Gmail) ---
# Per Gmail: abilita "App Password" nelle impostazioni Google Account
# https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tua@gmail.com
SMTP_PASS=xxxx-xxxx-xxxx-xxxx
REPORT_EMAIL=destinatario@email.com

# --- RILEVAMENTO GPS ---
# Raggio in metri entro cui un punto GPS viene considerato "nel luogo"
PROXIMITY_METERS=50
